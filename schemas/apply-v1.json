          "enum": [
            "info",
            "warning",
            "blocking"
          ]
        },
        "message": {
          "type": "string"
        },
        "occurrenceId": {
          "type": "string",
          "minLength": 1
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
